// firestore.rules
// Deploy com: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cardápio: leitura pública, escrita apenas autenticada
    match /menu/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
